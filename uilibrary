function Flux:Notify(opts)
    local title   = opts.Title or "Notification"
    local msg     = opts.Message or ""
    local dur     = opts.Duration or 3
    local icon    = opts.Icon or "ℹ️"
    local theme   = self.Theme

    if not self._notifHolder then
        self._notifHolder = Create("Frame", {
            Size             = UDim2.new(0, 280, 1, -20),
            Position         = UDim2.new(1, -290, 0, 10),
            BackgroundTransparency = 1,
            Parent           = self._gui,
        })
        ListLayout(self._notifHolder, 6)
    end

    local card = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        BackgroundTransparency = 0.05,
        Parent           = self._notifHolder,
    })
    Corner(card, 8)
    Stroke(card, theme.Accent, 1)

    local iconLabel = Create("TextLabel", {
        Size                  = UDim2.new(0, 30, 0, 30),
        Position              = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        Text                  = icon,
        TextSize              = 18,
        Parent                = card,
    })

    local titleLabel = Create("TextLabel", {
        Size                  = UDim2.new(1, -52, 0, 18),
        Position              = UDim2.new(0, 44, 0, 8),
        BackgroundTransparency = 1,
        Text                  = title,
        TextColor3            = theme.Accent,
        TextSize              = 13,
        Font                  = Enum.Font.GothamBold,
        TextXAlignment        = Enum.TextXAlignment.Left,
        TextTruncate          = Enum.TextTruncate.AtEnd,
        Parent                = card,
    })

    local msgLabel = Create("TextLabel", {
        Size                  = UDim2.new(1, -52, 0, 0),
        Position              = UDim2.new(0, 44, 0, 26),
        BackgroundTransparency = 1,
        Text                  = msg,
        TextColor3            = theme.TextDim,
        TextSize              = 11,
        Font                  = Enum.Font.Gotham,
        TextXAlignment        = Enum.TextXAlignment.Left,
        TextWrapped           = true,
        AutomaticSize         = Enum.AutomaticSize.Y,
        Parent                = card,
    })

    -- progress bar
    local bar = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 2),
        Position         = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    -- animate in
    task.defer(function()
        task.wait()
        local targetH = 26 + msgLabel.AbsoluteSize.Y + 18
        Tween(card, SmoothTween, {Size = UDim2.new(1, 0, 0, targetH)})
        task.wait(0.3)

        -- progress drain
        Tween(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 0, 2),
        })
        task.wait(dur)

        Tween(card, SmoothTween, {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
        })
        task.wait(0.3)
        card:Destroy()
    end)
end

