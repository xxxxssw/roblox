                ---------------------------------
                -- SLIDER
                ---------------------------------
                function groupObj:Slider(o)
                    o = o or {}
                    local name = o.Name or "Slider"
                    local min, max = o.Min or 0, o.Max or 100
                    local default = o.Default or min
                    local step = o.Step or 1
                    local suffix = o.Suffix or ""
                    local cb = o.Callback or function() end
                    local flag = o.Flag
                    local value = default

                    local row = Create("Frame", {
                        Size                   = UDim2.new(1, 0, 0, 30),
                        BackgroundTransparency = 1,
                        LayoutOrder            = NO(),
                        Parent                 = box,
                    })
                    local nameLbl = Create("TextLabel", {
                        Size                   = UDim2.new(1, 0, 0, 12),
                        BackgroundTransparency = 1,
                        Text                   = name,
                        TextSize               = 11,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        Parent                 = row,
                    })
                    local track = Create("Frame", {
                        Size            = UDim2.new(1, 0, 0, 14),
                        Position        = UDim2.new(0, 0, 0, 14),
                        BorderSizePixel = 0,
                        Parent          = row,
                    })
                    Corner(track, 2)
                    local trackStroke = Stroke(track, C3(0,0,0), 1)

                    local frac = math.clamp((default - min) / (max - min), 0, 1)
                    local fill = Create("Frame", {
                        Size            = UDim2.new(frac, 0, 1, 0),
                        BorderSizePixel = 0,
                        Parent          = track,
                    })
                    Corner(fill, 2)

                    local valLbl = Create("TextLabel", {
                        Size                   = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text                   = tostring(default) .. " " .. suffix,
                        TextSize               = 10,
                        TextColor3             = C3(255,255,255),
                        ZIndex                 = 3,
                        Parent                 = track,
                    })

                    AddSkin(window, function(th)
                        nameLbl.TextColor3 = th.TextDim
                        nameLbl.Font       = th.Font
                        track.BackgroundColor3 = th.InputBg
                        trackStroke.Color  = th.Border
                        fill.BackgroundColor3 = th.Accent
                        valLbl.Font        = th.FontMedium
                        valLbl.TextColor3  = th.TextActive
                    end)

                    local sliding = false
                    local function Update(x)
                        local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        local raw = min + (max - min) * rel
                        local stepped = math.floor(raw / step + 0.5) * step
                        stepped = math.clamp(stepped, min, max)
                        value = stepped
                        local f = (stepped - min) / (max - min)
                        fill.Size = UDim2.new(f, 0, 1, 0)
                        valLbl.Text = tostring(stepped) .. " " .. suffix
                        WriteFlag(flag, stepped)
                        pcall(cb, stepped)
                    end

                    track.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                            sliding = true; Update(i.Position.X)
                        end
                    end)
                    UserInput.InputChanged:Connect(function(i)
                        if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                            Update(i.Position.X)
                        end
                    end)
                    UserInput.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                            sliding = false
                        end
                    end)

                    local function SetV(v)
                        v = math.clamp(v, min, max)
                        value = v
                        local f = (v - min) / (max - min)
                        fill.Size = UDim2.new(f, 0, 1, 0)
                        valLbl.Text = tostring(v) .. " " .. suffix
                        WriteFlag(flag, v)
                        pcall(cb, v)
                    end
                    BindFlag(flag, SetV, function() return value end)

                    WriteFlag(flag, value)
                    if default ~= min then task.defer(function() pcall(cb, default) end) end

                    return { Set = function(_, v) SetV(v) end, Get = function() return value end }
                end

