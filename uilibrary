                    btn.MouseLeave:Connect(function()
                        Tween(btn, QuickTween, { BackgroundColor3 = window._theme.Accent })
                    end)
                    btn.MouseButton1Click:Connect(function()
                        Tween(btn, QuickTween, { BackgroundColor3 = window._theme.AccentDim })
                        task.delay(0.1, function()
                            Tween(btn, QuickTween, { BackgroundColor3 = window._theme.Accent })
                        end)
                        pcall(cb)
                    end)
                end

                ---------------------------------
                -- LABEL
                ---------------------------------
                function groupObj:Label(o)
                    o = o or {}
                    local lbl = Create("TextLabel", {
                        Size                   = UDim2.new(1, 0, 0, 14),
                        BackgroundTransparency = 1,
                        Text                   = o.Text or "",
                        TextSize               = 10,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        TextWrapped            = true,
                        AutomaticSize          = Enum.AutomaticSize.Y,
                        LayoutOrder            = NO(),
                        Parent                 = box,
                    })
                    AddSkin(window, function(th) lbl.TextColor3 = th.TextMuted; lbl.Font = th.Font end)
                    return { Set = function(_, v) lbl.Text = v end }
                end

                ---------------------------------
                -- TEXTBOX
                ---------------------------------
                function groupObj:TextBox(o)
                    o = o or {}
                    local name = o.Name or "Input"
                    local placeholder = o.Placeholder or ""
                    local cb = o.Callback or function() end
                    local flag = o.Flag

                    local row = Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 30),
                        BackgroundTransparency = 1,
                        LayoutOrder = NO(),
                        Parent = box,
                    })
                    local nameLbl = Create("TextLabel", {
                        Size = UDim2.new(1, 0, 0, 12),
                        BackgroundTransparency = 1,
                        Text = name,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = row,
                    })
                    local input = Create("TextBox", {
                        Size = UDim2.new(1, 0, 0, 16),
                        Position = UDim2.new(0, 0, 0, 14),
                        Text = "",
                        PlaceholderText = placeholder,
                        TextSize = 10,
                        BorderSizePixel = 0,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ClearTextOnFocus = false,
                        Parent = row,
                    })
                    Corner(input, 2)
                    local iStroke = Stroke(input, C3(0,0,0), 1)
                    Pad(input, 6, 6, 0, 0)

                    AddSkin(window, function(th)
                        nameLbl.TextColor3 = th.TextDim; nameLbl.Font = th.Font
                        input.BackgroundColor3 = th.InputBg
                        input.TextColor3 = th.Text
                        input.PlaceholderColor3 = th.TextMuted
                        input.Font = th.Font
                        iStroke.Color = th.Border
                    end)

                    input.FocusLost:Connect(function(enter)
                        WriteFlag(flag, input.Text)
                        if enter then pcall(cb, input.Text) end
                    end)
                    BindFlag(flag, function(v) input.Text = tostring(v) end, function() return input.Text end)

                    return { Set = function(_, v) input.Text = tostring(v) end, Get = function() return input.Text end }
                end

                ---------------------------------
                -- KEYBIND
                ---------------------------------
                function groupObj:Keybind(o)
                    o = o or {}
                    local name = o.Name or "Keybind"
                    local default = o.Default or Enum.KeyCode.Unknown
                    local cb = o.Callback or function() end
                    local flag = o.Flag
                    local current = default

                    local row = Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 18),
                        BackgroundTransparency = 1,
                        LayoutOrder = NO(),
                        Parent = box,
                    })
                    local lbl = Create("TextLabel", {
                        Size = UDim2.new(1, -70, 1, 0),
                        BackgroundTransparency = 1,
                        Text = name,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = row,
                    })
                    local kBtn = Create("TextButton", {
                        Size = UDim2.new(0, 60, 0, 16),
                        Position = UDim2.new(1, -60, 0.5, -8),
                        BorderSizePixel = 0,
                        Text = current.Name or "...",
                        TextSize = 10,
                        AutoButtonColor = false,
                        Parent = row,
                    })
                    Corner(kBtn, 2)
                    local kStroke = Stroke(kBtn, C3(0,0,0), 1)

                    AddSkin(window, function(th)
                        lbl.TextColor3 = th.TextDim; lbl.Font = th.Font
                        kBtn.BackgroundColor3 = th.InputBg
                        kBtn.TextColor3 = th.Accent
                        kBtn.Font = th.Font
                        kStroke.Color = th.Border
                    end)

                    local listening = false
                    kBtn.MouseButton1Click:Connect(function()
                        listening = true
                        kBtn.Text = "..."
                    end)
                    UserInput.InputBegan:Connect(function(input, gpe)
                        if listening then
                            if input.UserInputType == Enum.UserInputType.Keyboard then
                                current = input.KeyCode
                                kBtn.Text = current.Name
                                listening = false
                                WriteFlag(flag, current)
                            end
                        else
                            if not gpe and input.KeyCode == current and current ~= Enum.KeyCode.Unknown then
                                pcall(cb, current)
                            end
                        end
                    end)

                    BindFlag(flag, function(v) current = v; kBtn.Text = v.Name end, function() return current end)
                    WriteFlag(flag, current)

                    return { Set = function(_, k) current = k; kBtn.Text = k.Name; WriteFlag(flag, k) end, Get = function() return current end }
                end

                ---------------------------------
                -- COLORPICKER (real HSV popup)
                ---------------------------------
                function groupObj:ColorPicker(o)
                    o = o or {}
                    local name = o.Name or "Color"
                    local default = o.Default or window._theme.Accent
                    local cb = o.Callback or function() end
                    local flag = o.Flag
                    local current = default

                    local row = Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 18),
                        BackgroundTransparency = 1,
                        LayoutOrder = NO(),
                        Parent = box,
                    })
                    local lbl = Create("TextLabel", {
                        Size = UDim2.new(1, -24, 1, 0),
                        BackgroundTransparency = 1,
                        Text = name,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = row,
                    })
                    local sq = Create("TextButton", {
                        Size = UDim2.new(0, 18, 0, 12),
                        Position = UDim2.new(1, -18, 0.5, -6),
                        BackgroundColor3 = current,
                        BorderSizePixel = 0,
                        Text = "",
                        AutoButtonColor = false,
                        Parent = row,
                    })
                    Corner(sq, 1)
                    local sqStroke = Stroke(sq, C3(0,0,0), 1)

                    AddSkin(window, function(th)
                        lbl.TextColor3 = th.TextDim; lbl.Font = th.Font
                        sqStroke.Color = th.Border
                    end)

                    -- HSV popup panel
                    local popup
                    local function BuildPopup()
                        if popup then return end
                        local th = window._theme
                        popup = Create("Frame", {
                            Size = UDim2.new(0, 170, 0, 140),
                            BackgroundColor3 = th.GroupBg,
                            BorderSizePixel = 0,
                            ZIndex = 50,
                            Visible = false,
                            Parent = window._gui,
                        })
                        Corner(popup, th.CornerRadius)
                        Stroke(popup, th.Border, 1)

                        -- saturation/value box (colored by hue)
                        local svBox = Create("ImageLabel", {
                            Size = UDim2.new(0, 140, 0, 100),
                            Position = UDim2.new(0, 8, 0, 8),
                            BackgroundColor3 = C3(255, 0, 0),
                            BorderSizePixel = 0,
                            Image = "",
                            ZIndex = 51,
                            Parent = popup,
                        })
                        -- white horizontal gradient (saturation)
                        local gradS = Create("UIGradient", {
                            Color = ColorSequence.new(C3(255,255,255), C3(255,0,0)),
                            Parent = svBox,
                        })
                        -- black vertical gradient (value)
                        local shade = Create("Frame", {
                            Size = UDim2.new(1, 0, 1, 0),
                            BackgroundColor3 = C3(0,0,0),
                            BorderSizePixel = 0,
                            ZIndex = 52,
                            Parent = svBox,
                        })
                        Create("UIGradient", {
                            Color = ColorSequence.new(C3(0,0,0), C3(0,0,0)),
                            Transparency = NumberSequence.new({
                                NumberSequenceKeypoint.new(0, 1),
                                NumberSequenceKeypoint.new(1, 0),
                            }),
                            Rotation = 90,
                            Parent = shade,
                        })
                        local svCursor = Create("Frame", {
                            Size = UDim2.new(0, 6, 0, 6),
                            BackgroundColor3 = C3(255,255,255),
                            BorderSizePixel = 0,
                            AnchorPoint = Vector2.new(0.5, 0.5),
                            ZIndex = 53,
                            Parent = svBox,
                        })
                        Corner(svCursor, 999)
                        Stroke(svCursor, C3(0,0,0), 1)

                        -- hue bar
                        local hueBar = Create("Frame", {
                            Size = UDim2.new(0, 14, 0, 100),
                            Position = UDim2.new(0, 152, 0, 8),
                            BorderSizePixel = 0,
                            ZIndex = 51,
                            Parent = popup,
                        })
                        Create("UIGradient", {
                            Color = ColorSequence.new({
                                ColorSequenceKeypoint.new(0.00, C3(255,0,0)),
                                ColorSequenceKeypoint.new(0.17, C3(255,255,0)),
                                ColorSequenceKeypoint.new(0.33, C3(0,255,0)),
                                ColorSequenceKeypoint.new(0.50, C3(0,255,255)),
                                ColorSequenceKeypoint.new(0.67, C3(0,0,255)),
                                ColorSequenceKeypoint.new(0.83, C3(255,0,255)),
                                ColorSequenceKeypoint.new(1.00, C3(255,0,0)),
                            }),
                            Rotation = 90,
                            Parent = hueBar,
                        })
                        local hueCursor = Create("Frame", {
                            Size = UDim2.new(1, 4, 0, 2),
                            Position = UDim2.new(0, -2, 0, 0),
                            BackgroundColor3 = C3(255,255,255),
                            BorderSizePixel = 0,
                            ZIndex = 53,
                            Parent = hueBar,
                        })

                        local hex = Create("TextLabel", {
                            Size = UDim2.new(1, -16, 0, 20),
                            Position = UDim2.new(0, 8, 1, -24),
                            BackgroundColor3 = th.InputBg,
                            BorderSizePixel = 0,
                            TextSize = 10,
                            ZIndex = 51,
                            Parent = popup,
                        })
                        Corner(hex, 2)
                        Stroke(hex, th.Border, 1)

                        -- state
                        local h, s, v = 0, 1, 1
                        local function ColorFrom() return Color3.fromHSV(h, s, v) end
                        local function UpdateVisuals()
                            svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                            svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                            hueCursor.Position = UDim2.new(0, -2, h, 0)
                            local col = ColorFrom()
                            sq.BackgroundColor3 = col
                            hex.TextColor3 = C3(255,255,255)
                            hex.Font = th.Font
                            hex.Text = string.format("#%02X%02X%02X",
                                math.floor(col.R*255), math.floor(col.G*255), math.floor(col.B*255))
                            current = col
                            WriteFlag(flag, col)
                            pcall(cb, col)
                        end
                        -- init from current
                        local dh, ds, dv = Color3.toHSV(current)
                        h, s, v = dh, ds, dv
                        UpdateVisuals()

                        local draggingSV, draggingH = false, false
                        svBox.InputBegan:Connect(function(i)
                            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                                draggingSV = true
                                local rx = math.clamp((i.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                                local ry = math.clamp((i.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                                s, v = rx, 1 - ry; UpdateVisuals()
                            end
                        end)
                        hueBar.InputBegan:Connect(function(i)
                            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                                draggingH = true
                                local ry = math.clamp((i.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                                h = ry; UpdateVisuals()
                            end
                        end)
                        UserInput.InputChanged:Connect(function(i)
                            if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                            if draggingSV then
                                local rx = math.clamp((i.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                                local ry = math.clamp((i.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                                s, v = rx, 1 - ry; UpdateVisuals()
                            elseif draggingH then
                                local ry = math.clamp((i.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                                h = ry; UpdateVisuals()
                            end
                        end)
                        UserInput.InputEnded:Connect(function(i)
                            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                                draggingSV, draggingH = false, false
                            end
                        end)

                        -- close when clicking outside
                        UserInput.InputBegan:Connect(function(i, gpe)
                            if gpe then return end
                            if not popup.Visible then return end
                            if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                            local p = i.Position
                            local pos, sz = popup.AbsolutePosition, popup.AbsoluteSize
                            local sqP, sqS = sq.AbsolutePosition, sq.AbsoluteSize
                            local inPopup = p.X >= pos.X and p.X <= pos.X + sz.X and p.Y >= pos.Y and p.Y <= pos.Y + sz.Y
                            local inSq    = p.X >= sqP.X and p.X <= sqP.X + sqS.X and p.Y >= sqP.Y and p.Y <= sqP.Y + sqS.Y
                            if not inPopup and not inSq then popup.Visible = false end
                        end)

                        popup._setColor = function(col)
                            local nh, ns, nv = Color3.toHSV(col)
                            h, s, v = nh, ns, nv; UpdateVisuals()
                        end
                    end

                    sq.MouseButton1Click:Connect(function()
                        BuildPopup()
                        local sp = sq.AbsolutePosition
                        popup.Position = UDim2.fromOffset(sp.X - 140, sp.Y + 20)
                        popup.Visible = not popup.Visible
                    end)

                    BindFlag(flag, function(v)
                        current = v; sq.BackgroundColor3 = v
                        if popup then popup._setColor(v) end
                    end, function() return current end)
                    WriteFlag(flag, current)

                    return {
                        Set = function(_, c)
                            current = c; sq.BackgroundColor3 = c
                            WriteFlag(flag, c)
                            if popup then popup._setColor(c) end
                            pcall(cb, c)
                        end,
                        Get = function() return current end,
                    }
                end

                return groupObj
            end

            return subObj
        end

        return tabObj
    end

    return window
end

return Lib
