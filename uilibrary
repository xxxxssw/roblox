                        BorderSizePixel = 0,
                        Text            = "",
                        AutoButtonColor = false,
                        Parent          = row,
                    })
                    Corner(selBtn, 2)
                    local selStroke = Stroke(selBtn, C3(0,0,0), 1)
                    local selText = Create("TextLabel", {
                        Size                   = UDim2.new(1, -22, 1, 0),
                        Position               = UDim2.new(0, 6, 0, 0),
                        BackgroundTransparency = 1,
                        TextSize               = 10,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        Parent                 = selBtn,
                    })
                    local mark = Create("Frame", {
                        Size = UDim2.new(0,10,0,10), Position = UDim2.new(1,-14,0.5,-5),
                        BorderSizePixel = 0, Parent = selBtn,
                    })
                    Corner(mark, 1)

                    local function Summarize()
                        local picked = {}
                        for _, v in items do if state[v] then table.insert(picked, tostring(v)) end end
                        if #picked == 0 then selText.Text = "none"
                        elseif #picked <= 2 then selText.Text = table.concat(picked, ", ")
                        else selText.Text = picked[1] .. ", +" .. (#picked - 1) end
                    end

                    local itemFrames = {}
                    AddSkin(window, function(th)
                        nameLbl.TextColor3 = th.TextDim; nameLbl.Font = th.Font
                        selBtn.BackgroundColor3 = th.InputBg
                        selStroke.Color = th.Border
                        selText.TextColor3 = th.Text; selText.Font = th.Font
                        mark.BackgroundColor3 = th.Accent
                        for _, ib in itemFrames do
                            ib.BackgroundColor3 = th.InputBg
                            ib.Font = th.Font
                        end
                    end)

                    for i, item in ipairs(items) do
                        local ib = Create("TextButton", {
                            Size            = UDim2.new(1, 0, 0, itemH),
                            Position        = UDim2.new(0, 0, 0, closedH + (i-1)*itemH + 2),
                            BorderSizePixel = 0,
                            Text            = "  " .. tostring(item),
                            TextSize        = 10,
                            TextXAlignment  = Enum.TextXAlignment.Left,
                            AutoButtonColor = false,
                            Parent          = row,
                        })
                        Corner(ib, 2)
                        local function refresh()
                            ib.TextColor3 = state[item] and window._theme.Accent or window._theme.TextDim
                        end
                        refresh()
                        ib.MouseButton1Click:Connect(function()
                            state[item] = not state[item]
                            refresh(); Summarize()
                            local out = {}
                            for _, v in items do if state[v] then table.insert(out, v) end end
                            WriteFlag(flag, out)
                            pcall(cb, out)
                        end)
                        table.insert(itemFrames, ib)
                    end
                    Summarize()

                    local expanded = false
                    selBtn.MouseButton1Click:Connect(function()
                        expanded = not expanded
                        Tween(row, QuickTween, { Size = UDim2.new(1, 0, 0, expanded and openH or closedH) })
                    end)

                    local function SetList(lst)
                        state = {}
                        for _, v in lst do state[v] = true end
                        for i, item in ipairs(items) do
                            itemFrames[i].TextColor3 = state[item] and window._theme.Accent or window._theme.TextDim
                        end
                        Summarize()
                        local out = {}
                        for _, v in items do if state[v] then table.insert(out, v) end end
                        WriteFlag(flag, out)
                        pcall(cb, out)
                    end
                    BindFlag(flag, SetList, function()
                        local out = {}
                        for _, v in items do if state[v] then table.insert(out, v) end end
                        return out
                    end)

                    local initOut = {}
                    for _, v in items do if state[v] then table.insert(initOut, v) end end
                    WriteFlag(flag, initOut)

                    return { Set = function(_, l) SetList(l) end, Get = function()
                        local o = {}
                        for _, v in items do if state[v] then table.insert(o, v) end end
                        return o
                    end }
                end

                ---------------------------------
                -- COMBO (colored pills)
                ---------------------------------
                function groupObj:Combo(o)
                    o = o or {}
                    local name = o.Name or "Combo"
                    local options = o.Options or {}
                    local cb = o.Callback or function() end
                    local flag = o.Flag
                    local multi = o.Multi or false
                    local default = o.Default or {}
                    local active = {}
                    for _, v in default do active[v] = true end

                    local row = Create("Frame", {
                        Size                   = UDim2.new(1, 0, 0, 22),
                        BackgroundTransparency = 1,
                        LayoutOrder            = NO(),
                        Parent                 = box,
                    })

                    local nameLbl = Create("TextLabel", {
                        Size                   = UDim2.new(0.55, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text                   = name,
                        TextSize               = 11,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        Parent                 = row,
                    })

                    local btnHolder = Create("Frame", {
                        Size                   = UDim2.new(0.45, 0, 1, 0),
                        Position               = UDim2.new(0.55, 0, 0, 0),
                        BackgroundTransparency = 1,
                        Parent                 = row,
                    })
                    local ll = ListLayout(btnHolder, 4, Enum.FillDirection.Horizontal)
                    ll.HorizontalAlignment = Enum.HorizontalAlignment.Right
                    ll.VerticalAlignment   = Enum.VerticalAlignment.Center

                    AddSkin(window, function(th)
                        nameLbl.TextColor3 = th.TextDim; nameLbl.Font = th.Font
                    end)

                    local function CurrentOut()
                        if multi then
                            local p = {}
                            for _, op in options do if active[op.Value] then table.insert(p, op.Value) end end
                            return p
                        else
                            for _, op in options do if active[op.Value] then return op.Value end end
                            return nil
                        end
                    end
                    local function Fire() local o2 = CurrentOut(); WriteFlag(flag, o2); pcall(cb, o2) end

                    local btnRefs = {}
                    for _, opt in options do
                        local pill = Create("TextButton", {
                            Size                   = UDim2.new(0, 32, 0, 18),
                            BackgroundColor3       = opt.Color,
                            BorderSizePixel        = 0,
                            Text                   = opt.Label or "",
                            TextColor3             = C3(255, 255, 255),
                            TextSize               = 9,
                            Font                   = window._theme.FontBold,
                            AutoButtonColor        = false,
                            BackgroundTransparency = active[opt.Value] and 0 or 0.6,
                            Parent                 = btnHolder,
                        })
                        Corner(pill, 2)
                        btnRefs[opt.Value] = pill
                        pill.MouseButton1Click:Connect(function()
                            if multi then
                                active[opt.Value] = not active[opt.Value]
                            else
                                for k in active do active[k] = nil end
                                active[opt.Value] = true
                            end
                            for _, op2 in options do
                                btnRefs[op2.Value].BackgroundTransparency = active[op2.Value] and 0 or 0.6
                            end
                            Fire()
                        end)
                    end
                    AddSkin(window, function(th)
                        for _, p in btnRefs do p.Font = th.FontBold end
                    end)

                    if next(active) then task.defer(Fire) else WriteFlag(flag, CurrentOut()) end

                    return {
                        Set = function(_, tbl)
                            active = {}
                            for _, v in tbl do active[v] = true end
                            for _, op in options do
                                btnRefs[op.Value].BackgroundTransparency = active[op.Value] and 0 or 0.6
                            end
                            Fire()
                        end,
                        Get = CurrentOut,
                    }
                end

