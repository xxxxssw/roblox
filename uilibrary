                ---------------------------------
                -- MULTI-DROPDOWN
                ---------------------------------
                function groupObj:MultiDropdown(o)
                    o = o or {}
                    local name = o.Name or "Select"
                    local items = o.Items or {}
                    local default = o.Default or {}
                    local cb = o.Callback or function() end
                    local flag = o.Flag
                    local state = {}
                    for _, v in default do state[v] = true end

                    local closedH, itemH = 32, 18
                    local openH = closedH + (#items * itemH) + 4

                    local row = Create("Frame", {
                        Size                   = UDim2.new(1, 0, 0, closedH),
                        BackgroundTransparency = 1,
                        ClipsDescendants       = true,
                        LayoutOrder            = NO(),
                        Parent                 = box,
                    })
                    local nameLbl = Create("TextLabel", {
                        Size                   = UDim2.new(1, 0, 0, 12),
                        BackgroundTransparency = 1,
                        Text                   = name,
                        TextSize               = 11,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        Parent                 = row,
                    })
                    local selBtn = Create("TextButton", {
                        Size            = UDim2.new(1, 0, 0, 16),
