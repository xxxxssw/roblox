function Fatality:Notify(opts)
    local title = opts.Title or "fatality"
    local msg   = opts.Message or ""
    local dur   = opts.Duration or 3
    local theme = self.Theme

    if not self._notifHolder then
        self._notifHolder = Create("Frame", {
            Size               = UDim2.new(0, 260, 1, -20),
            Position           = UDim2.new(1, -270, 0, 10),
            BackgroundTransparency = 1,
            Parent             = self._gui,
        })
        ListLayout(self._notifHolder, 6)
    end

    local card = Create("Frame", {
        Size               = UDim2.new(1, 0, 0, 0),
        BackgroundColor3   = theme.GroupBg,
        BorderSizePixel    = 0,
        ClipsDescendants   = true,
        Parent             = self._notifHolder,
    })
    Corner(card, 3)
    Stroke(card, theme.Border, 1)

    Create("Frame", {
        Size             = UDim2.new(0, 2, 1, 0),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    Create("TextLabel", {
        Size                   = UDim2.new(1, -16, 0, 14),
        Position               = UDim2.new(0, 10, 0, 6),
        BackgroundTransparency = 1,
        Text                   = string.upper(title),
        TextColor3             = theme.Accent,
        TextSize               = 10,
        Font                   = FONT_BOLD,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = card,
    })

    local msgLbl = Create("TextLabel", {
        Size                   = UDim2.new(1, -16, 0, 0),
        Position               = UDim2.new(0, 10, 0, 22),
        BackgroundTransparency = 1,
        Text                   = msg,
        TextColor3             = theme.TextDim,
        TextSize               = 11,
        Font                   = FONT,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextWrapped            = true,
        AutomaticSize          = Enum.AutomaticSize.Y,
        Parent                 = card,
    })

    local bar = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    task.defer(function()
        task.wait()
        local h = 24 + msgLbl.AbsoluteSize.Y + 10
        Tween(card, SmoothTween, { Size = UDim2.new(1, 0, 0, h) })
        task.wait(0.2)
        Tween(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 0, 1),
        })
        task.wait(dur)
        Tween(card, SmoothTween, {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
        })
        task.wait(0.2)
        card:Destroy()
    end)
end

