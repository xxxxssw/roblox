-- merge overrides into a base theme, returning a fresh theme table
local function MergeTheme(base, overrides)
    local t = {}
    for k, v in base do t[k] = v end
    if overrides then for k, v in overrides do t[k] = v end end
    return t
end

-------------------------------------------------
-- TWEEN HELPERS
-------------------------------------------------
local QuickTween  = TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local SmoothTween = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local function Tween(o, i, p) local t = TweenServ:Create(o, i, p); t:Play(); return t end

-------------------------------------------------
-- INSTANCE HELPERS
-------------------------------------------------
local function Create(class, props, children)
    local inst = Instance.new(class)
    for k, v in props do if k ~= "Parent" then inst[k] = v end end
    if children then for _, c in children do c.Parent = inst end end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function Corner(p, r) return Create("UICorner", { CornerRadius = UDim.new(0, r or 3), Parent = p }) end
local function Stroke(p, color, thick) return Create("UIStroke", { Color = color or C3(0,0,0), Thickness = thick or 1, Parent = p }) end
local function Pad(p, l, r, t, b) return Create("UIPadding", {
    PaddingLeft   = UDim.new(0, l or 0),
    PaddingRight  = UDim.new(0, r or 0),
    PaddingTop    = UDim.new(0, t or 0),
    PaddingBottom = UDim.new(0, b or 0),
    Parent = p,
}) end
local function ListLayout(p, padding, dir, sortOrder)
    return Create("UIListLayout", {
        SortOrder     = sortOrder or Enum.SortOrder.LayoutOrder,
        Padding       = UDim.new(0, padding or 4),
        FillDirection = dir or Enum.FillDirection.Vertical,
        Parent = p,
    })
end

-------------------------------------------------
-- FLAGS
-------------------------------------------------
local function BindFlag(flag, setter, getter)
    if not flag then return end
    Lib._bindings[flag] = Lib._bindings[flag] or {}
    table.insert(Lib._bindings[flag], { set = setter, get = getter })
end

local function WriteFlag(flag, value)
    if not flag then return end
    Lib.Flags[flag] = value
end

function Lib:SaveConfig()
    local out = {}
    for k, v in self.Flags do
        if typeof(v) == "Color3" then
            out[k] = { _t = "Color3", r = v.R, g = v.G, b = v.B }
        elseif typeof(v) == "EnumItem" then
            out[k] = { _t = "EnumItem", enum = tostring(v.EnumType), name = v.Name }
        else
            out[k] = v
        end
    end
    return out
end

function Lib:LoadConfig(data)
    if type(data) ~= "table" then return end
    for k, v in data do
        local val = v
        if type(v) == "table" and v._t == "Color3" then
            val = Color3.new(v.r, v.g, v.b)
        elseif type(v) == "table" and v._t == "EnumItem" then
            local ok, e = pcall(function() return Enum[v.enum:match("Enum%.(.+)")][v.name] end)
            if ok then val = e end
        end
        Lib.Flags[k] = val
        if Lib._bindings[k] then
            for _, b in Lib._bindings[k] do pcall(b.set, val) end
        end
    end
end

