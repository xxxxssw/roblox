local function MakeScreenGui()
    local gui = Create("ScreenGui", {
        Name            = "FatalityUI_" .. tostring(math.random(1000, 9999)),
        ResetOnSpawn    = false,
        ZIndexBehavior  = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset  = true,
        DisplayOrder    = 999,
    })
    local ok = pcall(function() gui.Parent = game:GetService("CoreGui") end)
    if not ok then gui.Parent = LocalPlayer:WaitForChild("PlayerGui") end
    return gui
end

-------------------------------------------------
-- NOTIFICATIONS (use first window's theme, or Fatality as fallback)
-------------------------------------------------
function Lib:Notify(opts)
    local theme = (self._windows[1] and self._windows[1]._theme) or self.Themes.Fatality
    local title = opts.Title    or "note"
    local msg   = opts.Message  or ""
    local dur   = opts.Duration or 3

    self._gui = self._gui or MakeScreenGui()
    if not self._notifHolder then
        self._notifHolder = Create("Frame", {
            Size                   = UDim2.new(0, 260, 1, -20),
            Position               = UDim2.new(1, -270, 0, 10),
            BackgroundTransparency = 1,
            Parent                 = self._gui,
        })
        ListLayout(self._notifHolder, 6)
    end

    local card = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.GroupBg,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        Parent           = self._notifHolder,
    })
    Corner(card, theme.CornerRadius)
    Stroke(card, theme.Border, theme.BorderThick)

    Create("Frame", {
        Size             = UDim2.new(0, 2, 1, 0),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    Create("TextLabel", {
        Size                   = UDim2.new(1, -16, 0, 14),
        Position               = UDim2.new(0, 10, 0, 6),
        BackgroundTransparency = 1,
        Text                   = string.upper(title),
        TextColor3             = theme.Accent,
        TextSize               = 10,
        Font                   = theme.FontBold,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = card,
    })

    local msgLbl = Create("TextLabel", {
        Size                   = UDim2.new(1, -16, 0, 0),
        Position               = UDim2.new(0, 10, 0, 22),
        BackgroundTransparency = 1,
        Text                   = msg,
        TextColor3             = theme.TextDim,
        TextSize               = 11,
        Font                   = theme.Font,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextWrapped            = true,
        AutomaticSize          = Enum.AutomaticSize.Y,
        Parent                 = card,
    })

    local bar = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    task.defer(function()
        task.wait()
        local h = 24 + msgLbl.AbsoluteSize.Y + 10
        Tween(card, SmoothTween, { Size = UDim2.new(1, 0, 0, h) })
        task.wait(0.2)
        Tween(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 0, 1) })
        task.wait(dur)
        Tween(card, SmoothTween, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1 })
        task.wait(0.2)
        card:Destroy()
    end)
end

-------------------------------------------------
-- THEME BROADCASTER
-- Every styled instance registers a "skin" fn that receives the theme.
-- Calling window:SetTheme() replays them all.
-------------------------------------------------
local function AddSkin(window, fn)
    table.insert(window._skins, fn)
    fn(window._theme)
end

-------------------------------------------------
-- WINDOW
-------------------------------------------------
function Lib:Window(opts)
    opts = opts or {}
    local title    = opts.Title    or "MENU"
    local username = opts.Username or ""
    local expires  = opts.Expires  or ""
    local size     = opts.Size     or UDim2.new(0, 640, 0, 460)
    local key      = opts.Key      or Enum.KeyCode.RightShift

    -- resolve theme
    local themeBase
    if type(opts.Theme) == "string" then
        themeBase = self.Themes[opts.Theme] or self.Themes.Fatality
    elseif type(opts.Theme) == "table" and opts.Theme.WindowBg then
        themeBase = opts.Theme          -- full theme given
    else
        themeBase = self.Themes.Fatality
    end
    local theme = MergeTheme(themeBase, type(opts.Theme) == "table" and opts.Theme or nil)

    self._gui = self._gui or MakeScreenGui()

    local main = Create("Frame", {
        Size             = size,
        Position         = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint      = Vector2.new(0.5, 0.5),
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        Parent           = self._gui,
    })
    Corner(main, theme.CornerRadius)
    local mainStroke = Stroke(main, theme.Border, theme.BorderThick)

    local titleBar = Create("Frame", {
        Size            = UDim2.new(1, 0, 0, 38),
        BorderSizePixel = 0,
        Parent          = main,
    })

    local brand = Create("TextLabel", {
        Size                   = UDim2.new(0, 140, 1, 0),
        Position               = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Text                   = string.upper(title),
        TextSize               = 15,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = titleBar,
    })

    local tabHolder = Create("Frame", {
        Size                   = UDim2.new(1, -360, 1, 0),
        Position               = UDim2.new(0, 160, 0, 0),
        BackgroundTransparency = 1,
        Parent                 = titleBar,
    })
    ListLayout(tabHolder, 24, Enum.FillDirection.Horizontal)

    local userHolder = Create("Frame", {
        Size                   = UDim2.new(0, 196, 1, 0),
        Position               = UDim2.new(1, -212, 0, 0),
        BackgroundTransparency = 1,
        Parent                 = titleBar,
    })

    local userLbl, expLbl
    if username ~= "" then
        userLbl = Create("TextLabel", {
            Size                   = UDim2.new(1, -40, 0, 14),
            Position               = UDim2.new(0, 0, 0, 6),
            BackgroundTransparency = 1,
            Text                   = username,
            TextSize               = 11,
            TextXAlignment         = Enum.TextXAlignment.Right,
            Parent                 = userHolder,
        })
    end
    if expires ~= "" then
        expLbl = Create("TextLabel", {
            Size                   = UDim2.new(1, -40, 0, 12),
            Position               = UDim2.new(0, 0, 0, 20),
            BackgroundTransparency = 1,
            RichText               = true,
            Text                   = expires,
            TextSize               = 10,
            TextXAlignment         = Enum.TextXAlignment.Right,
            Parent                 = userHolder,
        })
    end

    local avatar = Create("Frame", {
        Size            = UDim2.new(0, 28, 0, 28),
        Position        = UDim2.new(1, -34, 0.5, -14),
        BorderSizePixel = 0,
        Parent          = userHolder,
    })
    Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = avatar })
    local avatarStroke = Stroke(avatar, C3(0,0,0), 1)

    local topLine = Create("Frame", {
        Size            = UDim2.new(1, 0, 0, 1),
        Position        = UDim2.new(0, 0, 1, -1),
        BorderSizePixel = 0,
        Parent          = titleBar,
    })

    local subTabBar = Create("Frame", {
        Size            = UDim2.new(1, 0, 0, 30),
        Position        = UDim2.new(0, 0, 0, 38),
        BorderSizePixel = 0,
        Parent          = main,
    })
    local subTabHolder = Create("Frame", {
        Size                   = UDim2.new(1, -32, 1, 0),
        Position               = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Parent                 = subTabBar,
    })
    ListLayout(subTabHolder, 20, Enum.FillDirection.Horizontal)

    local subTabLine = Create("Frame", {
        Size            = UDim2.new(1, 0, 0, 1),
        Position        = UDim2.new(0, 0, 1, -1),
        BorderSizePixel = 0,
        Parent          = subTabBar,
    })

    local contentArea = Create("Frame", {
        Size                   = UDim2.new(1, 0, 1, -68),
        Position               = UDim2.new(0, 0, 0, 68),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        Parent                 = main,
    })

    -- window object
    local window = {
        _main         = main,
        _tabHolder    = tabHolder,
        _subTabHolder = subTabHolder,
        _contentArea  = contentArea,
        _tabs         = {},
        _activeTab    = nil,
        _theme        = theme,
        _skins        = {},
        Theme         = theme,   -- public read
    }
    table.insert(self._windows, window)

    -- register self-skinning for the window chrome
    AddSkin(window, function(t)
        main.BackgroundColor3     = t.WindowBg
        mainStroke.Color          = t.Border
        mainStroke.Thickness      = t.BorderThick
        titleBar.BackgroundColor3 = t.TitleBg
        brand.TextColor3          = t.TextActive
        brand.Font                = t.FontBold
        if userLbl then userLbl.TextColor3 = t.Text; userLbl.Font = t.FontMedium end
        if expLbl then
            expLbl.TextColor3 = t.TextMuted
            expLbl.Font       = t.Font
            local n = string.match(expires, "%d+")
            local hex = string.format("#%02X%02X%02X",
                math.floor(t.Accent.R*255), math.floor(t.Accent.G*255), math.floor(t.Accent.B*255))
            if n then
                expLbl.Text = (string.gsub(expires, n, '<font color="'..hex..'">'..n..'</font>'))
            end
        end
        avatar.BackgroundColor3   = t.ElementBg
        avatarStroke.Color        = t.Accent
        topLine.BackgroundColor3  = t.TopLine
        subTabBar.BackgroundColor3 = t.SubTabBg
        subTabLine.BackgroundColor3 = t.Border
    end)

    -- drag
    do
        local dragging, dragStart, startPos
        titleBar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = i.Position; startPos = main.Position
            end
        end)
        titleBar.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
        UserInput.InputChanged:Connect(function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                local d = i.Position - dragStart
                main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
            end
        end)
    end

    -- visibility toggle
    local visible = true
    UserInput.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == key then
            visible = not visible
            main.Visible = visible
        end
    end)

    -- runtime theme switching
    function window:SetTheme(t)
        local base
        if type(t) == "string" then
            base = Lib.Themes[t] or Lib.Themes.Fatality
        elseif type(t) == "table" then
            base = MergeTheme(self._theme, t)
        else
            return
        end
        self._theme = MergeTheme(Lib.Themes.Fatality, base)
        self.Theme  = self._theme
        for _, fn in self._skins do pcall(fn, self._theme) end
    end

    function window:Destroy()
        main:Destroy()
    end

    ---------------------------------------------
    -- TAB
    ---------------------------------------------
    function window:Tab(tOpts)
        tOpts = tOpts or {}
        local tName = tOpts.Name or "TAB"

        local tBtn = Create("TextButton", {
            Size                   = UDim2.new(0, 0, 1, 0),
            AutomaticSize          = Enum.AutomaticSize.X,
            BackgroundTransparency = 1,
            Text                   = "",
            AutoButtonColor        = false,
            Parent                 = self._tabHolder,
        })
        local tLbl = Create("TextLabel", {
            Size                   = UDim2.new(0, 0, 1, 0),
            AutomaticSize          = Enum.AutomaticSize.X,
            BackgroundTransparency = 1,
            Text                   = string.upper(tName),
            TextSize               = 13,
            Parent                 = tBtn,
        })
        local tUL = Create("Frame", {
            Size                   = UDim2.new(1, 0, 0, 2),
            Position               = UDim2.new(0, 0, 1, -1),
            BorderSizePixel        = 0,
            BackgroundTransparency = 1,
            Parent                 = tBtn,
        })

        local tabObj = { _btn = tBtn, _lbl = tLbl, _ul = tUL, _subTabs = {}, _activeSub = nil }

        AddSkin(window, function(th)
            tLbl.Font = th.FontMedium
            tLbl.TextColor3 = (window._activeTab == tabObj) and th.TextActive or th.TextDim
            tUL.BackgroundColor3 = th.TopLine
        end)

        local function Activate()
            if window._activeTab and window._activeTab ~= tabObj then
                local old = window._activeTab
                Tween(old._lbl, QuickTween, { TextColor3 = window._theme.TextDim })
                Tween(old._ul,  QuickTween, { BackgroundTransparency = 1 })
                for _, s in old._subTabs do
                    s._btn.Visible = false
                    s._content.Visible = false
                    s._ul.BackgroundTransparency = 1
                end
            end
            window._activeTab = tabObj
            Tween(tLbl, QuickTween, { TextColor3 = window._theme.TextActive })
            Tween(tUL,  QuickTween, { BackgroundTransparency = 0 })
            for _, s in tabObj._subTabs do s._btn.Visible = true end
            if tabObj._activeSub then
                tabObj._activeSub._content.Visible = true
                tabObj._activeSub._ul.BackgroundTransparency = 0
            elseif tabObj._subTabs[1] then
                tabObj._subTabs[1]:_activate()
            end
        end

        tBtn.MouseButton1Click:Connect(Activate)
        tBtn.MouseEnter:Connect(function()
            if window._activeTab ~= tabObj then
                Tween(tLbl, QuickTween, { TextColor3 = window._theme.Text })
            end
        end)
        tBtn.MouseLeave:Connect(function()
            if window._activeTab ~= tabObj then
                Tween(tLbl, QuickTween, { TextColor3 = window._theme.TextDim })
            end
        end)

        table.insert(window._tabs, tabObj)
        if not window._activeTab then Activate() end

        -----------------------------------------
        -- SUBTAB
        -----------------------------------------
        function tabObj:SubTab(sOpts)
            sOpts = sOpts or {}
            local sName   = sOpts.Name or "SUB"
            local cols    = sOpts.Columns or 3   -- 1 / 2 / 3

            local sBtn = Create("TextButton", {
                Size                   = UDim2.new(0, 0, 1, 0),
                AutomaticSize          = Enum.AutomaticSize.X,
