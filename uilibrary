--[[
  ╔══════════════════════════════════════════════════════════════╗
  ║  FATALITY UI LIBRARY  v3.1  —  modular / themeable            ║
  ║                                                               ║
  ║  The Fatality CS2 look is the DEFAULT, but every color,       ║
  ║  border, font, padding is overridable. You can also swap      ║
  ║  themes live with Window:SetTheme("Midnight") etc.            ║
  ║                                                               ║
  ║  Quick start:                                                 ║
  ║    local Lib = loadstring(...)()                              ║
  ║    local W = Lib:Window({                                     ║
  ║        Title    = "MYCHEAT",                                  ║
  ║        Username = "player",                                   ║
  ║        Expires  = "lifetime",                                 ║
  ║        Theme    = "Fatality",  -- or "Midnight"/"Synthwave"   ║
  ║        -- or override: Theme = { Accent = Color3.new(...)}    ║
  ║    })                                                         ║
  ║    local T = W:Tab({ Name = "RAGE" })                         ║
  ║    local S = T:SubTab({ Name = "AIMBOT", Columns = 3 })       ║
  ║    local G = S:Group({ Name = "Target", Side = "Left" })      ║
  ║    G:Toggle   ({ Name = "Enabled", Flag = "aim.on" })         ║
  ║    G:Slider   ({ Name = "FOV", Min = 0, Max = 180, Flag = ...})║
  ║    G:Dropdown ({ Name = "Hitbox", Items = {...}, Flag = ... })║
  ║    G:MultiDropdown({ Name = "Bones", Items = {...} })         ║
  ║    G:Combo    ({ Name = "Prediction",                         ║
  ║        Options = {                                            ║
  ║            { Label = "A", Color = C3(255,60,60),  Value=1 },  ║
  ║            { Label = "B", Color = C3(60,255,120), Value=2 }}})║
  ║    G:Button   ({ Name = "Reset" })                            ║
  ║    G:Keybind  ({ Name = "Panic key", Flag = "panic" })        ║
  ║    G:TextBox  ({ Name = "Nickname" })                         ║
  ║    G:ColorPicker({ Name = "Box color", Default = C3(...) })   ║
  ║                                                               ║
  ║  Config persistence:                                          ║
  ║    local data = Lib:SaveConfig()     -- table of all flags    ║
  ║    Lib:LoadConfig(data)                                       ║
  ║                                                               ║
  ║  Runtime theming:                                             ║
  ║    W:SetTheme("Synthwave")                                    ║
  ║    W:SetTheme({ Accent = Color3.fromRGB(0,255,128) })         ║
  ║                                                               ║
  ║  Notifications:                                               ║
  ║    Lib:Notify({ Title="hi", Message="msg", Duration=3 })      ║
  ╚══════════════════════════════════════════════════════════════╝
]]

