            function subObj:_activate()
                if tabObj._activeSub and tabObj._activeSub ~= subObj then
                    local old = tabObj._activeSub
                    Tween(old._lbl, QuickTween, { TextColor3 = window._theme.TextDim })
                    Tween(old._ul,  QuickTween, { BackgroundTransparency = 1 })
                    old._content.Visible = false
                end
                tabObj._activeSub = subObj
                Tween(sLbl, QuickTween, { TextColor3 = window._theme.TextActive })
                Tween(sUL,  QuickTween, { BackgroundTransparency = 0 })
                content.Visible = true
            end

