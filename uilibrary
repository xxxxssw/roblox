function Flux:Notify(opts)
    local title = opts.Title or "flux"
    local msg   = opts.Message or ""
    local dur   = opts.Duration or 3
    local theme = self.Theme

    if not self._notifHolder then
        self._notifHolder = Create("Frame", {
            Size               = UDim2.new(0, 240, 1, -20),
            Position           = UDim2.new(1, -250, 0, 10),
            BackgroundTransparency = 1,
            Parent             = self._gui,
        })
        ListLayout(self._notifHolder, 4)
    end

    local card = Create("Frame", {
        Size               = UDim2.new(1, 0, 0, 0),
        BackgroundColor3   = theme.ElementBg,
        BorderSizePixel    = 0,
        ClipsDescendants   = true,
        Parent             = self._notifHolder,
    })
    Corner(card, 2)
    Stroke(card, theme.Border, 1)

    -- left accent bar
    Create("Frame", {
        Size             = UDim2.new(0, 2, 1, 0),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    local titleLabel = Create("TextLabel", {
        Size                  = UDim2.new(1, -16, 0, 14),
        Position              = UDim2.new(0, 10, 0, 6),
        BackgroundTransparency = 1,
        Text                  = string.lower(title),
        TextColor3            = theme.TextAccent,
        TextSize              = 11,
        Font                  = Enum.Font.Code,
        TextXAlignment        = Enum.TextXAlignment.Left,
        TextTruncate          = Enum.TextTruncate.AtEnd,
        Parent                = card,
    })

    local msgLabel = Create("TextLabel", {
        Size                  = UDim2.new(1, -16, 0, 0),
        Position              = UDim2.new(0, 10, 0, 20),
        BackgroundTransparency = 1,
        Text                  = msg,
        TextColor3            = theme.TextDim,
        TextSize              = 10,
        Font                  = Enum.Font.Code,
        TextXAlignment        = Enum.TextXAlignment.Left,
        TextWrapped           = true,
        AutomaticSize         = Enum.AutomaticSize.Y,
        Parent                = card,
    })

    -- bottom progress line
    local bar = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    task.defer(function()
        task.wait()
        local targetH = 20 + msgLabel.AbsoluteSize.Y + 12
        Tween(card, SmoothTween, {Size = UDim2.new(1, 0, 0, targetH)})
        task.wait(0.2)
        Tween(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 0, 1),
        })
        task.wait(dur)
        Tween(card, SmoothTween, {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
        })
        task.wait(0.2)
        card:Destroy()
    end)
end

