                end
            end)
            sBtn.MouseLeave:Connect(function()
                if tabObj._activeSub ~= subObj then
                    Tween(sLbl, QuickTween, { TextColor3 = window._theme.TextDim })
                end
            end)

            table.insert(tabObj._subTabs, subObj)
            if not tabObj._activeSub and window._activeTab == tabObj then
